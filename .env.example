VITE_SUPABASE_URL=https://bfbdoamqywlkgynjgway.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Tesla Fleet API (web portal OAuth — for admin fleet vehicle import)
# Client ID is public — safe to include here
VITE_TESLA_CLIENT_ID=your-tesla-client-id-here
# Redirect URI must match what is registered in the Tesla developer console
# Development:  http://localhost:5174/tesla-callback
# Production:   https://app.millogapp.se/tesla-callback
VITE_TESLA_WEB_REDIRECT_URI=http://localhost:5174/tesla-callback

# Stripe (web billing — publishable key is safe to expose)
# Get this from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── The following are Edge Function secrets only ──
# Set via: supabase secrets set STRIPE_SECRET_KEY=sk_live_...
# DO NOT put these in .env files — they must never reach the browser bundle.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_FLEET_MONTHLY_PRICE_ID=price_...      (129 kr/vehicle/month)
# STRIPE_PERSONAL_MONTHLY_PRICE_ID=price_...   (79 kr/month)
# STRIPE_PERSONAL_ANNUAL_PRICE_ID=price_...    (699 kr/year)
# APP_URL=https://app.millogapp.se
